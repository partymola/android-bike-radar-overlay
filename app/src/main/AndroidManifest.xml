<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Approximate location is used solely to compute sunrise/sunset for the
         front-light day/night auto-mode. Read once per ride session via
         getLastKnownLocation (no continuous tracking, no background
         polling). City-block accuracy is sufficient: a 10 km position
         error shifts computed sunrise by ~1 minute. If the permission is
         denied, auto-mode falls back to London-hardcoded times. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:targetApi="34" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_SHORT_SERVICE"
        tools:targetApi="34" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"
        tools:targetApi="34" />
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />

    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true" />

    <!-- Android 11+ package visibility: without this, getLaunchIntentForPackage
         for Bosch Flow returns null even when it is installed, so the
         "Open Flow to pair" action falls back to the Play Store instead of
         opening the app. -->
    <queries>
        <package android:name="com.bosch.ebike.onebikeapp" />
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BikeRadar"
        android:usesCleartextTraffic="true">
        <!-- HA URL: cleartext HTTP is allowed at OS level so LAN setups
             keep working. App-level refusal (HaUrlPolicy) blocks the
             bearer token from leaving over HTTP to non-LAN hosts. -->


        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BikeRadar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- No WAKE_LOCK permission and no PowerManager wakelock: the FGS's
             implicit wakelock is sufficient while the device is awake or
             actively dozing-light. In Doze (deep), `delay()` ticks driving
             the V2 watchdog and walk-away timer are deferred until the next
             maintenance window, so walk-away alerts fire late when the
             phone has been idle for several minutes. Acceptable trade-off:
             a wakelock would keep the radio class active in Doze and erase
             much of the battery budget on parked-phone idle. If this
             becomes user-visible, request REQUEST_IGNORE_BATTERY_OPTIMIZATIONS
             (intent-based, user must approve in Settings) rather than
             holding a wakelock from the service. -->
        <service
            android:name=".BikeRadarService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <receiver
            android:name=".BatteryScanReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="es.jjrh.bikeradar.BATTERY_SCAN_RESULT" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Dev-only (adb) replay/synthetic actions. Not exported: a peer
             app must never be able to start the debug overlay/replay FGSes,
             even on a device where the user has flipped devModeUnlocked. adb
             still reaches it with an explicit component, which shell may
             deliver to a non-exported receiver:
               am broadcast -n es.jjrh.bikeradar/.RemoteControlReceiver \
                            -a es.jjrh.bikeradar.DEV_REPLAY -->
        <receiver
            android:name=".RemoteControlReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="es.jjrh.bikeradar.DEV_REPLAY" />
                <action android:name="es.jjrh.bikeradar.DEV_SYNTH" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".InternalControlReceiver"
            android:exported="false" />

        <service
            android:name=".DebugOverlayService"
            android:exported="false"
            android:foregroundServiceType="shortService"
            tools:targetApi="34" />

        <service
            android:name=".ReplayService"
            android:exported="false"
            android:foregroundServiceType="shortService"
            tools:targetApi="34" />

        <service
            android:name=".SyntheticScenarioService"
            android:exported="false"
            android:foregroundServiceType="shortService"
            tools:targetApi="34" />

        <service
            android:name=".ScreenshotCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection"
            tools:targetApi="34" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
