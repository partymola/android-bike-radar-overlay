    <string name="main_system_value_mqtt_ready">MQTT ready</string>
    <string name="main_system_value_unreachable">Unreachable</string>

    <!-- CLOSE PASSES stats card. -->
    <string name="main_section_close_passes">Close passes</string>
    <string name="main_close_passes_caption">this ride</string>
    <string name="main_close_passes_empty_hint">Enable Settings → Alerts → Log to Home Assistant to keep a history of overtakes inside your set lateral threshold.</string>
    <plurals name="main_close_passes_count_desc">
        <item quantity="one"><xliff:g id="count" example="1">%1$d</xliff:g> close pass this ride</item>
        <item quantity="other"><xliff:g id="count" example="3">%1$d</xliff:g> close passes this ride</item>
