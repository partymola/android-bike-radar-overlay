    <!-- Dashcam-ownership prompt card (first-run flows). -->
    <string name="main_dashcam_prompt_title">Do you run a dashcam?</string>
    <string name="main_dashcam_prompt_body">The overlay shows its battery and flags when it stops broadcasting.</string>
